{
  "name": "kerulabs",
  "version": "0.8.1",
  "description": "KeruLabs - Football Tactics & Code Lab",
  "main": "dist-electron/main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:electron": "vite --mode electron",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build",
    "build:electron": "tsc && vite build --mode electron && electron-builder",
    "preview": "vite preview",
    "preview:web": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "check:circular": "madge --circular --extensions ts,tsx --ts-config tsconfig.json src/",
    "test:e2e:ui": "playwright test --ui",
    "electron:dev": "concurrently \"vite --mode electron\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build:electron",
    "prepare": "git config core.hooksPath .husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:a11y": "test-storybook",
    "check:licenses": "license-checker --production --failOn 'GPL-2.0;GPL-3.0;AGPL-1.0;AGPL-3.0;SSPL-1.0;EUPL-1.1;EUPL-1.2;CPAL-1.0;OSL-3.0;RPL-1.5' --summary",
    "release:notes": "node scripts/extract-release-notes.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-table": "^8.21.3",
    "camera-controls": "2.10.1",
    "dompurify": "^3.4.7",
    "idb": "^8.0.0",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "react-router-dom": "^7.17.0",
    "three": "^0.170.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.14",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/react-vite": "^10.2.14",
    "@storybook/test-runner": "^0.24.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "axe-playwright": "^2.2.2",
    "concurrently": "^9.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.1",
    "eslint-plugin-storybook": "^10.2.14",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "storybook": "^10.2.14",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.4.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "lodash-es": ">=4.18.0"
    }
  },
  "overrides": {
    "dagre-d3-es": {
      "lodash-es": "^4.18.1"
    },
    "mermaid": {
      "uuid": "^14.0.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ]
  },
  "author": "Takao Fujii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/takataka6/kerulabs.git"
  },
  "homepage": "https://github.com/takataka6/kerulabs",
  "bugs": {
    "url": "https://github.com/takataka6/kerulabs/issues"
  }
}
