  "code.lab.plugin.guide.title": "How to Create a Plugin",
  "code.lab.plugin.guide.tabStructure": "Structure",
  "code.lab.plugin.guide.tabSections": "Section Types",
  "code.lab.plugin.guide.tabExample": "Full Example",
  "code.lab.plugin.guide.structureDesc": "A plugin is a JSON file that adds custom lessons to CodeLab. Copy the base structure below, add sections inside the sections array, and import the JSON file from the plugin manager page.",
  "code.lab.plugin.guide.baseStructureTitle": "Base Structure (Template)",
  "code.lab.plugin.guide.fieldsTitle": "Field Descriptions",
  "code.lab.plugin.guide.baseFieldsDesc": "kerulabs_plugin (required): Version string. Use \"1.0\"\ntype (required): Plugin type. Use \"lesson\"\nmetadata.id (required): Unique plugin ID (alphanumeric and hyphens)\nmetadata.name (required): Plugin name { \"ja\": \"Japanese\", \"en\": \"English\" }\nmetadata.author (required): Author name\nmetadata.version (required): Version number (e.g. \"1.0.0\")\nmetadata.description (required): Plugin description\ndata.lessonId (required): Unique lesson ID (alphanumeric and hyphens)\ndata.category (required): Category (see list below)\ndata.title (required): Lesson title\ndata.description (required): Lesson description\ndata.icon (required): Emoji icon (e.g. \"📦\")\ndata.gradient (required): Tailwind gradient (e.g. \"from-blue-600 to-cyan-500\")\ndata.sections (required): Array of sections (at least 1 required)",
  "code.lab.plugin.guide.categoriesTitle": "Available Categories (data.category values)",
  "code.lab.plugin.guide.catProgramming": "Programming Basics",
  "code.lab.plugin.guide.catFileFormats": "File Formats",
  "code.lab.plugin.guide.catGit": "Git",
  "code.lab.plugin.guide.catArchitecture": "Architecture",
  "code.lab.plugin.guide.catTesting": "Testing",
  "code.lab.plugin.guide.catCustom": "Custom",
  "code.lab.plugin.guide.sectionsDesc": "Click each section type to view the JSON format and required fields.",
  "code.lab.plugin.guide.expandAll": "Expand all",
  "code.lab.plugin.guide.collapseAll": "Collapse all",
  "code.lab.plugin.guide.sectionHeading": "Heading",
  "code.lab.plugin.guide.sectionHeadingDesc": "Displays a section heading within the lesson.",
  "code.lab.plugin.guide.fieldsHeading": "type (required): \"heading\"\ntext (required): Bilingual text { \"ja\": \"...\", \"en\": \"...\" }",
  "code.lab.plugin.guide.sectionParagraph": "Paragraph",
  "code.lab.plugin.guide.sectionParagraphDesc": "Displays explanatory text content.",
  "code.lab.plugin.guide.fieldsParagraph": "type (required): \"paragraph\"\ntext (required): Bilingual text { \"ja\": \"...\", \"en\": \"...\" }",
  "code.lab.plugin.guide.sectionCodeBlock": "Code Block",
  "code.lab.plugin.guide.sectionCodeBlockDesc": "Displays code with syntax highlighting. Line highlighting is also supported.",
  "code.lab.plugin.guide.fieldsCodeBlock": "type (required): \"codeBlock\"\nlanguage (required): Language name (e.g. \"javascript\", \"python\", \"html\")\ncode (required): Code string (use \\n for newlines)\nhighlightLines (optional): Array of line numbers to highlight (e.g. [1, 3])",
  "code.lab.plugin.guide.sectionMiniPitchDemo": "3D Pitch Demo",
  "code.lab.plugin.guide.sectionMiniPitchDemoDesc": "Visualizes concepts by placing players on a 3D soccer pitch.",
  "code.lab.plugin.guide.fieldsMiniPitchDemo": "type (required): \"miniPitchDemo\"\ndescription (optional): Description text { \"ja\": \"...\", \"en\": \"...\" }\ncameraPosition (optional): Camera position [x, y, z] (default: [0, 12, -8])\nplayers (required): Array of players\n  Each player: { x: number, z: number, number?: integer, name?: string, color: \"#hex\" }\n  x: horizontal position (-5 to 5), z: vertical position (-7 to 7)\n  * Pitch size is a 10 wide x 14 deep miniature field",
  "code.lab.plugin.guide.sectionMiniPitchSteps": "Step-by-Step 3D Demo",
  "code.lab.plugin.guide.sectionMiniPitchStepsDesc": "A step-by-step 3D demo where player positions change at each step. Navigate with prev/next buttons.",
  "code.lab.plugin.guide.fieldsMiniPitchSteps": "type (required): \"miniPitchSteps\"\ndescription (optional): Description text { \"ja\": \"...\", \"en\": \"...\" }\ncameraPosition (optional): Camera position [x, y, z]\nsteps (required): Array of steps (at least 1)\n  Each step: { label: { \"ja\": \"...\", \"en\": \"...\" }, players: [...] }\n  Player format is the same as miniPitchDemo",
  "code.lab.plugin.guide.sectionMermaidDiagram": "Mermaid Diagram",
  "code.lab.plugin.guide.sectionMermaidDiagramDesc": "Renders diagrams such as flowcharts and sequence diagrams using Mermaid syntax.",
  "code.lab.plugin.guide.fieldsMermaidDiagram": "type (required): \"mermaidDiagram\"\ndescription (optional): Description text { \"ja\": \"...\", \"en\": \"...\" }\ncode (required): Mermaid syntax string (use \\n for newlines)\nSupported diagram types: flowchart, sequence, class, state, gantt, etc.",
  "code.lab.plugin.guide.sectionInteractiveDemo": "Interactive Demo",
  "code.lab.plugin.guide.sectionInteractiveDemoDesc": "An interactive 3D demo where users change state via UI controls and the scene updates reactively.",
  "code.lab.plugin.guide.fieldsInteractiveDemo": "type (required): \"interactiveDemo\"\ndescription (optional): Description text\ncameraPosition (optional): Camera position [x, y, z]\nstate (required): State variable definitions (key → { type, default, min?, max? })\ncontrols (required): Array of UI controls (see \"Control Types\" below)\nEither scene or scenes is required:\n  scene: Single scene { players: [...] } with $variable bindings\n  scenes: Scene map by state value { \"value1\": { players: [...] }, \"value2\": { players: [...] } }",
  "code.lab.plugin.guide.controlTypesTitle": "Control Types (for interactiveDemo controls)",
  "code.lab.plugin.guide.controlTypesDesc": "buttonGroup: Button toggle { type: \"buttonGroup\", bind: \"stateKey\", options: [{ value: \"val\", label: { ja, en } }] }\ntextInput: Text input { type: \"textInput\", bind: \"stateKey\", label?: { ja, en }, maxLength?: number }\nnumberInput: Number input { type: \"numberInput\", bind: \"stateKey\", label?: { ja, en } }\ntoggle: ON/OFF toggle { type: \"toggle\", bind: \"stateKey\", label?: { ja, en } }\nslider: Range slider { type: \"slider\", bind: \"stateKey\", label?: { ja, en } }",
  "code.lab.plugin.guide.exampleDesc": "Below is a complete plugin JSON example covering all 7 section types. Copy and edit it.",
  "code.lab.plugin.guide.copy": "Copy",
  "code.lab.plugin.guide.close": "Close",
